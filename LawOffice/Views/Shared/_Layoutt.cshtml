<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - سامانه دفتر حقوقی</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />

    <!-- AdminLTE CSS -->
    <link rel="stylesheet" href="~/plugins/fontawesome-free/css/all.min.css">
    <!-- Theme style -->
    <link rel="stylesheet" href="~/dist/css/adminlte.min.css">
    <!-- RTL style -->
    bootstrap-icons.min.css"
    <link rel="stylesheet" href="~/dist/css/rtl.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="hold-transition sidebar-mini layout-fixed">

    <div class="wrapper">
        <!-- Navbar -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button" id="sidebarToggle">
                        <i class="bi bi-list"></i>
                    </a>
                </li>
            </ul>

            <ul class="navbar-nav mr-auto">
                <li class="nav-item">
                    <span class="navbar-text">
                        <span class="badge bg-primary me-2" id="userRoleBadge"></span>
                        <span id="navUserName"></span>
                    </span>
                </li>
            </ul>
        </nav>

        <!-- Main Sidebar -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <a href="/Dashboard/Index" class="brand-link text-center">
                <i class="bi bi-briefcase-fill"></i>
                <span class="brand-text font-weight-light">دفتر حقوقی</span>
            </a>

            <div class="sidebar">
                <div class="user-panel mt-3 pb-3 mb-3 d-flex">
                    <div class="info">
                        <span class="d-block text-white" id="userFullName"></span>
                    </div>
                </div>

                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" id="sidebarMenu">
                        <li class="nav-item">
                            <a href="/Dashboard/Index" class="nav-link">
                                <i class="nav-icon bi bi-speedometer2"></i>
                                <p>داشبورد</p>
                            </a>
                        </li>

                        <li class="nav-item role-menu" data-roles="Staff,Lawyer">
                            <a href="/Clients" class="nav-link">
                                <i class="nav-icon bi bi-people"></i>
                                <p>موکلین</p>
                            </a>
                        </li>

                        <li class="nav-item role-menu" data-roles="Staff,Lawyer">
                            <a href="/Cases" class="nav-link">
                                <i class="nav-icon bi bi-folder2-open"></i>
                                <p>پرونده‌ها</p>
                            </a>
                        </li>

                        <li class="nav-item role-menu" data-roles="Staff,Lawyer">
                            <a href="/Appointments" class="nav-link">
                                <i class="nav-icon bi bi-calendar3"></i>
                                <p>نوبت‌دهی</p>
                            </a>
                        </li>

                        <li class="nav-item role-menu" data-roles="Staff,Lawyer">
                            <a href="/CourtSessions" class="nav-link">
                                <i class="nav-icon bi bi-bank"></i>
                                <p>جلسات دادگاه</p>
                            </a>
                        </li>

                        <li class="nav-item role-menu" data-roles="Staff,Lawyer">
                            <a href="/Financials" class="nav-link">
                                <i class="nav-icon bi bi-cash-stack"></i>
                                <p>امور مالی</p>
                            </a>
                        </li>

                        <li class="nav-item role-menu" data-roles="Client">
                            <a href="/Cases" class="nav-link">
                                <i class="nav-icon bi bi-folder2-open"></i>
                                <p>پرونده‌های من</p>
                            </a>
                        </li>

                        <li class="nav-item mt-3">
                            <a href="#" class="nav-link text-danger" id="btnLogout">
                                <i class="nav-icon bi bi-box-arrow-right"></i>
                                <p>خروج</p>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </aside>

        <!-- Content Wrapper -->
        <div class="content-wrapper">
            <section class="content-header">
                <div class="container-fluid">
                    <h1>@ViewData["Title"]</h1>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </section>
        </div>

        <!-- Footer -->
        <footer class="main-footer text-center">
            <strong>سامانه دفتر حقوقی</strong> - تمامی حقوق محفوظ است
        </footer>
    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer"></div>
    <!-- AdminLTE App -->
    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/dist/js/adminlte.min.js"></script>
    <script src="~/js/persian-date.min.js"></script>
    <script src="~/js/persian-datepicker.min.js"></script>
    <script src="~/js/toast-manager.js" asp-append-version="true"></script>
    <script src="~/js/auth-manager.js" asp-append-version="true"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // ابتدا مقداردهی اولیه
            AuthManager.init();

            // سپس آپدیت کردن ظاهر (منوها و نام) پس از لود کامل صفحه
            if(AuthManager.isAuthenticated()) {
                AuthManager.updateUI();
            }
        });
    </script>
    <script>
        // اطمینان از کارکرد منوی موبایل
        $(document).ready(function() {
            // فعال‌سازی PushMenu برای موبایل
            $('[data-widget="pushmenu"]').PushMenu('init');

            // اگر AdminLTE لود نشده، fallback دستی
            $('#sidebarToggle').on('click', function(e) {
                e.preventDefault();
                $('body').toggleClass('sidebar-open sidebar-collapse');
            });

            // بستن منو با کلیک روی overlay در موبایل
            $(document).on('click', '.sidebar-overlay', function() {
                $('body').removeClass('sidebar-open').addClass('sidebar-collapse');
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
