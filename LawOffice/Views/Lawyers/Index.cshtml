@{
    ViewData["Title"] = "مدیریت وکلا";
}
@section Styles {
    <!-- اضافه کردن استایل Select2 -->
    <link href="~/css/select2.min.css" rel="stylesheet" />

    <style>
        /* استایل سفارشی برای هماهنگی Select2 با بوت‌استرپ و قالب راست‌چین (RTL) */
        .select2-container .select2-selection--single {
            height: 38px;
            border: 1px solid #ced4da;
            border-radius: 0.25rem;
        }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 36px;
            padding-right: 12px;
        }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 36px;
            left: 10px;
            right: auto;
        }

        .select2-container {
            width: 100% !important;
        }
    </style>
}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">لیست وکلا</h3>
        <button class="btn btn-primary" onclick="openLawyerModal()">
            <i class="bi bi-plus-circle"></i> ثبت وکیل جدید
        </button>
    </div>

    <div class="card shadow-sm">
        <div class="card-body table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>نام و نام خانوادگی</th>
                        <th>شماره پروانه</th>
                        <th>تخصص</th>
                        <th>شماره تماس</th>
                        <th>عملیات</th>
                    </tr>
                </thead>
                <tbody id="lawyersTableBody">
                    <!-- داده‌ها توسط جاوااسکریپت در اینجا قرار می‌گیرند -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="lawyerModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">ثبت وکیل جدید</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="lawyerForm">
                    <input type="hidden" id="lawyerId" value="0">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">نام</label>
                            <input type="text" class="form-control" id="firstName" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">نام خانوادگی</label>
                            <input type="text" class="form-control" id="lastName" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">نام پدر</label>
                            <input type="text" class="form-control" id="fatherName" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">کد ملی</label>
                            <input type="text" class="form-control" id="nationalCode" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">شماره پروانه وکالت</label>
                            <input type="text" class="form-control" id="barNumber">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">تخصص</label>
                            <input type="text" class="form-control" id="specialization">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">پایه</label>
                            <input type="text" class="form-control" id="level">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">شماره تماس</label>
                            <input type="text" class="form-control" id="phoneNumber">
                        </div>
                        <div class="col-md-6">
                            <label for="UserId" class="form-label">حساب کاربری (کاربر سیستم)</label>
                            <select class="form-control select2-users" id="UserId" name="UserId">
                                <option value="">-- انتخاب کاربر --</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">بیوگرافی / توضیحات</label>
                            <textarea class="form-control" id="bio" rows="3"></textarea>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">انصراف</button>
                <button type="button" class="btn btn-success" onclick="saveLawyer()">ذخیره</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/select2.min.js"></script>

    <script src="~/js/lawyers.js"></script>
}
