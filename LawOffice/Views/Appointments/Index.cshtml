@{
    ViewData["Title"] = "مدیریت نوبت‌ها";
}

@section Styles {
    <link rel="stylesheet" href="~/css/jdatetime-picker/jalalidatepicker.min.css" />
    <style>
        jdp-container, .jdp-container {
            z-index: 99999 !important;
        }
        /* استایل برای لیست نوبت‌ها */
        .appointment-item {
            transition: all 0.2s ease-in-out;
        }

            .appointment-item:hover {
                background-color: #f8f9fa;
            }
    </style>
}

<div class="container-fluid">
    <div class="row">
        <!-- ستون سمت راست: تقویم و فرم -->
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">افزودن / ویرایش نوبت</h5>
                </div>
                <div class="card-body">
                    <form id="appointmentForm">
                        <input type="hidden" id="appointmentId" />

                        <div class="mb-3">
                            <label for="appointmentDate" class="form-label">تاریخ نوبت <span class="text-danger">*</span></label>
                            <input type="text" id="appointmentDate" class="form-control"  data-jdp required autocomplete="off">
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="startTime" class="form-label">ساعت شروع <span class="text-danger">*</span></label>
                                <input type="time" id="startTime" class="form-control" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="endTime" class="form-label">ساعت پایان <span class="text-danger">*</span></label>
                                <input type="time" id="endTime" class="form-control" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="clientId" class="form-label">موکل</label>
                            <select id="clientId" class="form-select">
                                <option value="">انتخاب کنید...</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="lawyerId" class="form-label">وکیل</label>
                            <select id="lawyerId" class="form-select">
                                <option value="">انتخاب کنید...</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="description" class="form-label">توضیحات</label>
                            <textarea id="description" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="mb-3 form-check">
                            <input type="checkbox" id="sendReminder" class="form-check-input">
                            <label for="sendReminder" class="form-check-label">ارسال پیامک یادآوری</label>
                        </div>

                        <div class="d-flex justify-content-end mt-4">
                            <button type="button" class="btn btn-secondary me-2" onclick="clearForm()">انصراف</button>
                            <button type="button" class="btn btn-primary" onclick="saveAppointment()">ذخیره نوبت</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- ستون سمت چپ: لیست نوبت‌ها -->
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0">نوبت‌های تاریخ انتخاب شده</h5>
                </div>
                <div class="card-body">
                    <div id="appointmentsList" class="list-group">
                        <p class="text-muted text-center py-4">لطفاً یک تاریخ را از فرم سمت راست انتخاب کنید.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/jdatetime-picker/jalalidatepicker.min.js"></script>
    <script src="~/js/appointments.js"></script>
}
