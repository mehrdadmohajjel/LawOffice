@{
    ViewData["Title"] = "مدیریت جلسات دادگاه";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">جلسات دادگاه</h4>
        <button class="btn btn-primary" onclick="openModal()">
            <i class="bi bi-plus-lg"></i> ثبت جلسه جدید
        </button>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>شماره پرونده</th>
                            <th>موکل</th>
                            <th>وکیل</th>
                            <th>تاریخ جلسه</th>
                            <th>ساعت</th>
                            <th>مجتمع قضایی / شعبه</th>
                            <th>وضعیت</th>
                            <th>عملیات</th>
                        </tr>
                    </thead>
                    <tbody id="courtSessionsTableBody">
                        <!-- داده‌ها توسط جاوااسکریپت بارگذاری می‌شوند -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="courtSessionModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">ثبت جلسه جدید</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="courtSessionForm">
                    <input type="hidden" id="sessionId">

                    <div class="mb-3">
                        <label class="form-label">پرونده</label>
                        <select class="form-select" id="caseId" required></select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">وکیل</label>
                        <select class="form-select" id="lawyerId" required></select>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">تاریخ جلسه</label>
                            <input type="text" class="form-control" id="sessionDate" data-jdp required autocomplete="off">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">ساعت</label>
                            <input type="time" class="form-control" id="sessionTime" required>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">مجتمع قضایی</label>
                            <input type="text" class="form-control" id="courtName" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">شعبه</label>
                            <input type="text" class="form-control" id="branch" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">توضیحات (اختیاری)</label>
                        <textarea class="form-control" id="notes" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">انصراف</button>
                <button type="submit" form="courtSessionForm" class="btn btn-primary">ذخیره</button>

            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/jdatetime-picker/jalalidatepicker.min.css" />
    <link rel="stylesheet" href="~/plugins/sweetalert2/sweetalert2.min.css" />
    <style>
        jdp-container, .jdp-container {
            z-index: 99999 !important;
        }
        /* استایل برای لیست نوبت‌ها */
        .appointment-item {
            transition: all 0.2s ease-in-out;
        }

            .appointment-item:hover {
                background-color: #f8f9fa;
            }
    </style>
}
@section Scripts {
    <script src="~/plugins/sweetalert2/sweetalert2.min.js"></script>
    <script src="~/js/select2.min.js"></script>
    <script src="~/js/jdatetime-picker/jalalidatepicker.min.js"></script>
    <script src="~/js/court-sessions.js"></script>
    <script>
        jalaliDatepicker.startWatch(); // فعال‌سازی تقویم شمسی
    </script>
}
